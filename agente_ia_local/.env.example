# Use 127.0.0.1:3307 quando o tunnel SSH estiver habilitado.
AGENTE_DB_HOST=127.0.0.1
AGENTE_DB_PORT=3307
AGENTE_DB_DATABASE=
AGENTE_DB_USERNAME=
AGENTE_DB_PASSWORD=
AGENTE_DB_READONLY_USERNAME=
AGENTE_DB_READONLY_PASSWORD=
AGENTE_DB_TENANT_PREFIX=tenant_
